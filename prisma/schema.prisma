// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum Gender {
  MALE
  FEMALE
  OTHERS
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum TokenType {
  ACCESS
  REFRESH
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum EventStatus {
  DRAFT
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum EventLocationType {
  ONLINE
  OFFLINE
  HYBRID
}

enum RundownStatus {
  DRAFT
  PENDING
  ONGOING
  SKIPPED
  FINISHED
}

enum RundownVisibility {
  PUBLIC
  INTERNAL
  RESTRICTED
}

enum OrganizerStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum EventOrganizerStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum MemberStatus {
  PENDING
  ACTIVE
  INACTIVE
  BANNED
  REJECTED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  QRIS
  BANK_TRANSFER
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
}

enum TicketStatus {
  UNUSED
  ATTENDED
  CANCELLED
  REFUNDED
}

enum MediaType {
  IMAGE
  VIDEO
}

model User {
  id              Int        @id @default(autoincrement())
  uuid            String     @unique @default(uuid())
  email           String     @unique
  password        String
  firstName       String     @map("first_name")
  lastName        String     @map("last_name")
  username        String     @unique
  isEmailVerified Boolean    @default(false) @map("is_email_verified")
  isVerified      Boolean    @default(false) @map("is_verified")
  status          UserStatus @default(ACTIVE)
  role            UserRole   @default(USER)

  profile     String?
  birthdate   DateTime?
  bio         String?   @db.Text
  phoneNumber String?   @map("phone_number")
  gender      Gender?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tokens           Token[]
  events           Event[]
  organizers       Organizer[]
  organizerMembers OrganizerMember[]
  transactions     Transaction[]
  tickets          Ticket[]
  followOrganizers FollowOrganizer[]
  favouriteEvents  FavouriteEvent[]

  followers FollowUser[] @relation("Following")
  following FollowUser[] @relation("Follower")

  @@map("users")
}

model Token {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique @default(uuid())
  token     String
  type      TokenType
  expiresAt DateTime  @map("expires_at")

  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("tokens")
}

model Event {
  id       Int         @id @default(autoincrement())
  uuid     String      @unique @default(uuid())
  title    String
  start    DateTime
  end      DateTime
  status   EventStatus @default(DRAFT)
  isPublic Boolean     @default(false) @map("is_public")

  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  banner      String? @db.Text
  description String? @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  categories      Category[]
  rundowns        Rundown[]
  eventOrganizers EventOrganizer[]
  ticketTiers     TicketTier[]
  transactions    Transaction[]

  favouritedBy   FavouriteEvent[]
  eventLocations EventLocation[]
  eventReviews   EventReview[]

  @@map("events")
}

model EventLocation {
  id       Int               @id @default(autoincrement())
  uuid     String            @unique @default(uuid())
  type     EventLocationType
  location String

  eventId Int   @map("event_id")
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  rundowns Rundown[]

  @@map("event_locations")
}

model Category {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  eventId Int   @map("event_id")
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  categoryDetails CategoryDetail[]

  @@map("categories")
}

model CategoryDetail {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())
  name String

  categoryId Int      @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("category_details")
}

model Rundown {
  id         Int               @id @default(autoincrement())
  uuid       String            @unique @default(uuid())
  title      String
  date       DateTime
  start      DateTime
  end        DateTime
  status     RundownStatus     @default(DRAFT)
  visibility RundownVisibility @default(PUBLIC)

  eventId Int   @map("event_id")
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  locationId Int?           @map("location_id")
  location   EventLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  description String?   @db.Text
  actualStart DateTime? @map("actual_start")
  actualEnd   DateTime? @map("actual_end")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("rundowns")
}

model Organizer {
  id         Int             @id @default(autoincrement())
  uuid       String          @unique @default(uuid())
  name       String
  status     OrganizerStatus @default(ACTIVE)
  isVerified Boolean         @default(false) @map("is_verified")
  isPublic   Boolean         @default(true) @map("is_public")

  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  description String? @db.Text
  logo        String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  roles            Role[]
  organizerMembers OrganizerMember[]
  eventOrganizers  EventOrganizer[]

  followers        FollowOrganizer[]
  organizerReviews OrganizerReview[]

  @@map("organizers")
}

model Role {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())
  name String

  organizerId Int       @map("organizer_id")
  organizer   Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  description String? @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  organizerMembers      OrganizerMember[]
  eventOrganizerDetails EventOrganizerDetail[]

  @@map("roles")
}

model OrganizerMember {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  organizerId Int       @map("organizer_id")
  organizer   Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  userId      Int       @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId      Int?      @map("role_id")
  role        Role?     @relation(fields: [roleId], references: [id], onDelete: SetNull)

  status MemberStatus @default(PENDING)
  reason String?      @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("organizer_members")
}

model EventOrganizer {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  eventId     Int       @map("event_id")
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organizerId Int       @map("organizer_id")
  organizer   Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  status       EventOrganizerStatus @default(PENDING)
  rejectReason String?              @map("reject_reason") @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  eventOrganizerDetails EventOrganizerDetail[]

  @@map("event_organizers")
}

model EventOrganizerDetail {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  eventOrganizerId Int            @map("event_organizer_id")
  eventOrganizer   EventOrganizer @relation(fields: [eventOrganizerId], references: [id], onDelete: Cascade)
  roleId           Int            @map("role_id")
  role             Role           @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("event_organizer_details")
}

model TicketTier {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid())
  name      String
  price     Float
  quantity  Int
  startSale DateTime @map("start_sale")
  endSale   DateTime @map("end_sale")

  eventId Int   @map("event_id")
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  description String? @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tickets Ticket[]

  @@map("ticket_tiers")
}

model Transaction {
  id            Int           @id @default(autoincrement())
  uuid          String        @unique @default(uuid())
  invoiceNumber String        @unique @map("invoice_number")
  amount        Float
  paymentMethod PaymentMethod @map("payment_method")
  status        PaymentStatus @default(PENDING) @map("status")

  userId  Int   @map("user_id")
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId Int   @map("event_id")
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  paidAt DateTime? @map("paid_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tickets Ticket[]

  @@map("transactions")
}

model Ticket {
  id     Int          @id @default(autoincrement())
  uuid   String       @unique @default(uuid())
  code   String       @unique
  status TicketStatus @default(UNUSED)

  transactionId Int         @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  ticketTierId  Int         @map("ticket_tier_id")
  ticketTier    TicketTier  @relation(fields: [ticketTierId], references: [id], onDelete: Cascade)
  userId        Int         @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("tickets")
}

model FollowUser {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  followingId Int  @map("following_id")
  following   User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  followerId  Int  @map("follower_id")
  follower    User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("follow_users")
}

model FollowOrganizer {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  organizerId Int       @map("organizer_id")
  organizer   Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  userId      Int       @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("follow_organizers")
}

model FavouriteEvent {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  eventId Int   @map("event_id")
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  Int   @map("user_id")
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("favourite_events")
}

model Review {
  id      Int     @id @default(autoincrement())
  uuid    String  @unique @default(uuid())
  rating  Int
  comment String? @db.Text

  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")
  medias           Media[]
  eventReviews     EventReview[]
  organizerReviews OrganizerReview[]

  @@map("reviews")
}

model Media {
  id   Int       @id @default(autoincrement())
  uuid String    @unique @default(uuid())
  url  String
  type MediaType

  reviewId Int?    @map("review_id")
  review   Review? @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("media")
}

model EventReview {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  eventId  Int    @map("event_id")
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  reviewId Int    @map("review_id")
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("event_reviews")
}

model OrganizerReview {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  organizerId Int       @map("organizer_id")
  organizer   Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  reviewId    Int       @map("review_id")
  review      Review    @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("organizer_reviews")
}
